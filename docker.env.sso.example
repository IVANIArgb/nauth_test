# Скопируйте в .env и запускайте:
#   docker compose -f docker-compose.yml -f docker-compose.sso.yml up -d --build

WEB_PORT=8080
FLASK_ENV=development
SECRET_KEY=замените-на-случайную-строку

# Логин, который nginx передаёт во Flask (кириллица — через X-Remote-User-B64 автоматически)
SSO_DEFAULT_USER=testadmin
# SSO_DEFAULT_USER=Пользователь

TRUST_REMOTE_USER=true
DOCKER_AUTH_FALLBACK=false
KERBEROS_GSSAPI_ENABLED=false
ALLOW_INSECURE_NEGOTIATE_HEURISTIC=false

# Опционально: AD в контейнере
# LDAP_ENABLED=true
# LDAP_SERVER=ldap://dc01.example.com:389
# LDAP_BASE_DN=DC=example,DC=com
# LDAP_BIND_DN=CN=svc,OU=Service,DC=example,DC=com
# LDAP_PASSWORD=

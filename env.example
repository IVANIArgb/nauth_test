# Скопируйте в .env в корне проекта и подставьте свои значения.
# Файлы .env в .gitignore. Разделы: локальный dev | Docker | production.

# ========== ОБЩЕЕ ==========
FLASK_ENV=development
# Плейсхолдер ниже не запустится без INSECURE_DEV_SECRET=true (см. C5 в security-and-quality-audit.md)
SECRET_KEY=замените-на-длинную-случайную-строку
INSECURE_DEV_SECRET=false
DEBUG=true
LOG_LEVEL=DEBUG

# ========== СЕРВЕР (run.py / gunicorn) ==========
HOST=127.0.0.1
PORT=5000
RUN_WITH_GUNICORN=false
GUNICORN_WORKERS=2
GUNICORN_THREADS=
GUNICORN_TIMEOUT=120

# ========== БАЗА И ФАЙЛЫ ==========
# Если не задано — sqlite:///<корень_проекта>/database/users_courses.db
# DATABASE_URL=sqlite:///database/users_courses.db
DATABASE_INIT_SAMPLE_DATA=false
MAX_CONTENT_LENGTH=104857600
# Путь к корню учебного контента (категории/курсы на диске). Пусто = папка categories-data в корне проекта.
# Важно: не копируйте .env с другого ПК — путь вида C:\Users\ДругойЛогин\... даст «Отказано в доступе» у вас.
CONTENT_ROOT_DIR=
BACKUP_DIR=
BACKUP_RETENTION_DAYS=14
BACKUP_INCLUDE_DB=true
BACKUP_ON_CONTENT_ROOT_CHANGE=true
DB_SEED_ON_START=false
DB_RECREATE_ON_START=false

# ========== АУТЕНТИФИКАЦИЯ ==========
KERBEROS_AUTH_ENABLED=true
KERBEROS_SERVICE_NAME=HTTP
KERBEROS_REALM=EXAMPLE.COM
KERBEROS_KEYTAB=
KERBEROS_KDC_HOST=localhost
KERBEROS_KDC_PORT=88

# Kerberos в Linux/контейнере (GSSAPI): см. kerberos/README.txt и docker-compose.kerberos.yml
# KERBEROS_GSSAPI_ENABLED=true
# KERBEROS_HOSTNAME=portal.example.com
# KRB5_CONF_PATH=./kerberos/krb5.conf
# KRB5_KEYTAB_PATH=./kerberos/http.keytab

# Active Directory по LDAP (в контейнере; на Windows хоста — PowerShell Get-ADUser).
# LDAP_ENABLED=true
# LDAP_SERVER=ldap://dc01.example.com:389
# LDAP_BASE_DN=DC=example,DC=com
# LDAP_USER=EXAMPLE\\svc_ldap
# LDAP_PASSWORD=
# LDAP_USE_SSL=false

# Docker с Kerberos: DOCKER_AUTH_FALLBACK=false, см. kerberos/env.kerberos.example

TEST_MODE=false
# false = TEST_MODE без подмены логина (нужен Kerberos/Windows/прокси)
TEST_MODE_AUTH_BYPASS=true
TEST_MODE_DEFAULT_USER=testadmin
TEST_MODE_DEFAULT_FULL_NAME=

# Только dev: подмена личности одним пользователем (в production запрещено)
ROOT_TEST_AUTH_ENABLED=false
ROOT_TEST_USERNAME=root
ROOT_TEST_FORCE_ROLE=

# Docker без Kerberos: стабильный логин (в production запрещено)
DOCKER_AUTH_FALLBACK=false
DOCKER_DEFAULT_USER=testadmin

# За доверенным reverse-proxy (nginx oauth2-proxy)
TRUST_REMOTE_USER=false
TRUST_REMOTE_USER_CONFIRM=false
# IP/CIDR прокси, которому доверяем X-Remote-User (пусто = 127.0.0.1,::1 + Docker-сети). '*' только для dev.
TRUSTED_PROXY_IPS=
REMOTE_USER_HEADERS=X-Remote-User,X-Forwarded-User,Remote-User,Cf-Access-Authenticated-User-Email
# Redis для общих rate-limit при нескольких воркерах (пусто = memory:// на процесс)
# RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/0

# Без keytab в контейнере: билет Kerberos проверяет reverse-proxy (IIS Integrated Windows Auth и т.п.),
# прокси передаёт логин в заголовке (см. TRUST_REMOTE_USER). Не включайте эвристику Negotiate.
ALLOW_INSECURE_NEGOTIATE_HEURISTIC=false

ACCEPT_CONTAINER_OS_USER=false

DEFAULT_USER_DEPARTMENT=
DEFAULT_USER_POSITION=

# ========== ТЕРМИНАЛ (страница команд) ==========
TERMINAL_ROLE_COMMANDS_ENABLED=true
ALLOW_TERMINAL_IN_PROD=false

# ========== COOKIES И ЗАГОЛОВКИ ==========
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=15552000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=false
SECURITY_HSTS_PRELOAD=false
CSP_ENABLED=true
CSP_REPORT_ONLY=true
# CSP_POLICY=...
# Отладка /debug/auth при TRUST_REMOTE_USER (по умолчанию выключено)
# ALLOW_DEBUG_AUTH=false
# NDJSON agent debug (debug-*.log) — только при AGENT_DEBUG_LOG=true
# AGENT_DEBUG_LOG=false

# ========== КОРПОРАТИВНЫЙ WINDOWS vs ДОМАШНЯЯ РАЗРАБОТКА ==========
# На рабочем ПК обычно: домен, Kerberos, иногда reverse-proxy с REMOTE_USER.
# Дома часто: localhost, нет билета, удобнее пустой CONTENT_ROOT_DIR или свой каталог.
# Сравнение сред: см. docs/mds/corporate-vs-local-deployment.md
# В логе при старте ищите learningsite.startup — там фактический путь контента и флаги auth.

# ========== ПРОЧЕЕ ==========
SEND_FILE_MAX_AGE_DEFAULT=604800

# Docker SSO + LDAP (Active Directory) — без keytab, рекомендуется для корпоративного ПК.
# Скопируйте:  copy docker/docker.env.sso-ad.example .env
# Запуск:     run-server.bat  или  update.bat

WEB_PORT=8080
FLASK_ENV=development
SECRET_KEY=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_64_СИМВОЛА
INSECURE_DEV_SECRET=true

# DEV на ноутбуке без Kerberos: nginx подставляет один логин. На СЕРВЕРЕ не нужно —
# IIS/nginx с Kerberos/NTLM сам кладёт X-Remote-User того, кто реально вошёл.
SSO_DEFAULT_USER=ВАШ_ЛОГИН_AD
# SSO_DEFAULT_USER=ManakovIV
# Локальный dev-кэш AD с ПК (не для продакшена): AD_HOST_PROFILE_CACHE_DEV=true

TRUST_REMOTE_USER=true
TRUSTED_PROXY_IPS=127.0.0.1,::1,172.16.0.0/12
DOCKER_AUTH_FALLBACK=false
KERBEROS_GSSAPI_ENABLED=false
ALLOW_INSECURE_NEGOTIATE_HEURISTIC=false

# --- Active Directory по LDAP (профиль: ФИО, отдел, должность) ---
LDAP_ENABLED=true
LDAP_SERVER=ldap://dc01.ВАШ.ДОМЕН:389
LDAP_BASE_DN=DC=ВАШ,DC=ДОМЕН
LDAP_USER=DOMAIN\svc_ldap_read
LDAP_BIND_DN=
LDAP_PASSWORD=ПАРОЛЬ_СЛУЖБЫ
LDAP_USE_SSL=false

KERBEROS_REALM=ВАШ.REALM.HERE
KERBEROS_AUTH_ENABLED=true

# Минимум для docker compose. Полный список: env.example
# Kerberos+LDAP: см. kerberos/env.kerberos.example

WEB_PORT=8000
FLASK_ENV=development
SECRET_KEY=замените-на-случайную-строку

DOCKER_AUTH_FALLBACK=true
DOCKER_DEFAULT_USER=testadmin

# --- Kerberos + LDAP (с docker-compose.kerberos.yml) ---
# KERBEROS_GSSAPI_ENABLED=true
# KERBEROS_HOSTNAME=portal.example.com
# KERBEROS_REALM=EXAMPLE.COM
# LDAP_ENABLED=true
# LDAP_SERVER=ldap://dc01.example.com:389
# LDAP_BASE_DN=DC=example,DC=com
# LDAP_USER=DOMAIN\\svc_ldap
# LDAP_PASSWORD=
# KRB5_CONF_PATH=./kerberos/krb5.conf
# KRB5_KEYTAB_PATH=./kerberos/http.keytab

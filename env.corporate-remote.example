# =============================================================================
# Шаблон для УДАЛЁННОГО / КОРПОРАТИВНОГО Windows-ПК (домен, AD, Kerberos)
# =============================================================================
# 1) Скопируйте в корень проекта как файл `.env` (именно `.env`, без .example).
# 2) Замените все YOUR_* и примеры домена на свои значения.
# 3) Не переносите .env с домашнего ПК целиком — пути C:\Users\... будут чужими.
#
# Запуск и пояснения: docs/mds/remote-pc-launch.md
# =============================================================================

# ----- Режим приложения -----
# development — удобно для внутреннего HTTP (cookies Secure не принудительны).
# production — только за HTTPS-прокси (иначе сессии могут вести себя неожиданно).
FLASK_ENV=development

SECRET_KEY=СГЕНЕРИРУЙТЕ_ДЛИННУЮ_СЛУЧАЙНУЮ_СТРОКУ_МИНИМУМ_32_СИМВОЛА
DEBUG=false
LOG_LEVEL=INFO

# ----- Сервер (run.py: встроенный Flask; на Windows gunicorn не используется) -----
# 127.0.0.1 — только с этой машины; 0.0.0.0 — доступ из локальной сети (осторожно с политикой ИБ).
HOST=127.0.0.1
PORT=5000
RUN_WITH_GUNICORN=false

# ----- База и контент (пути — под ВАШЕГО пользователя Windows) -----
# Пусто = каталог categories-data в корне репозитория (часто оптимально для первого запуска).
# Или свой каталог, куда у текущего пользователя есть полный доступ, например:
# CONTENT_ROOT_DIR=D:\LearningSiteData\categories-data
CONTENT_ROOT_DIR=

DATABASE_INIT_SAMPLE_DATA=false
MAX_CONTENT_LENGTH=1073741824
BACKUP_DIR=
BACKUP_RETENTION_DAYS=14
BACKUP_INCLUDE_DB=true
BACKUP_ON_CONTENT_ROOT_CHANGE=true
DB_SEED_ON_START=false
DB_RECREATE_ON_START=false

# ----- Kerberos / AD (корпоративный домен) -----
KERBEROS_AUTH_ENABLED=true
KERBEROS_SERVICE_NAME=HTTP
# Реальное имя realm домена (часто COMPANY.LOCAL или COMPANY.COM):
KERBEROS_REALM=YOUR.REALM.HERE

# KDC — обычно контроллер домена или "localhost" если krb5 указывает на DC.
KERBEROS_KDC_HOST=your-dc01.your.domain
KERBEROS_KDC_PORT=88

# Keytab на Windows (если проверяете Negotiate в самом Flask через GSSAPI):
# KERBEROS_KEYTAB=C:\path\to\http.keytab

# Если билет проверяет только reverse-proxy (IIS / nginx), в приложении GSSAPI выключен:
KERBEROS_GSSAPI_ENABLED=false
# FQDN сайта как в SPN (HTTP/fqdn@REALM), если включите GSSAPI:
KERBEROS_HOSTNAME=portal.your.domain

# LDAP — если приложение ходит в AD не через PowerShell Get-ADUser (например Linux/контейнер).
# На Windows-хосте с RSAT чаще достаточно LDAP_ENABLED=false (тогда профиль через PowerShell).
LDAP_ENABLED=false
# LDAP_SERVER=ldap://your-dc01.your.domain:389
# LDAP_BASE_DN=DC=your,DC=domain
# LDAP_USER=YOURDOMAIN\\svc_ldap
# LDAP_PASSWORD=
# LDAP_USE_SSL=false

# ----- Тестовые режимы (на корпоративном ПК держите выключенными) -----
TEST_MODE=false
TEST_MODE_DEFAULT_USER=testadmin
ROOT_TEST_AUTH_ENABLED=false
DOCKER_AUTH_FALLBACK=false
DOCKER=false

# ----- Вариант A: приложение напрямую в браузере (без прокси с REMOTE_USER) -----
# Логин берётся из Windows-сессии (sam_account_name) и/или Negotiate при GSSAPI.
TRUST_REMOTE_USER=false
TRUST_REMOTE_USER_CONFIRM=false

# ----- Вариант B: за IIS / nginx с Windows Auth или другим SSO (прокси подставляет логин) -----
# Раскомментируйте и выключите дублирующий блок A выше (TRUST_REMOTE_USER=false).
# TRUST_REMOTE_USER=true
# TRUST_REMOTE_USER_CONFIRM=true
# REMOTE_USER_HEADERS=X-Remote-User,X-Remote-User-B64,Remote-User

ALLOW_INSECURE_NEGOTIATE_HEURISTIC=false
ACCEPT_CONTAINER_OS_USER=false

DEFAULT_USER_DEPARTMENT=
DEFAULT_USER_POSITION=

# ----- Терминал на странице команд -----
# В production без ALLOW_TERMINAL_IN_PROD приложение не стартует, если TERMINAL включён.
TERMINAL_ROLE_COMMANDS_ENABLED=false
ALLOW_TERMINAL_IN_PROD=false

# ----- Cookies и заголовки -----
# За HTTPS-терминатором в production обычно true (в ProductionConfig по умолчанию так).
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=15552000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=false
SECURITY_HSTS_PRELOAD=false
CSP_ENABLED=true
CSP_REPORT_ONLY=true

SEND_FILE_MAX_AGE_DEFAULT=604800

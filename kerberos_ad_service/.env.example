APP_ENV=prod
HOST=0.0.0.0
PORT=5000
DEBUG=false
K8S_NAMESPACE=kerberos-sso
K8S_HOSTNAME=app.example.com
IMAGE=ghcr.io/your-org/kerberos-sso:latest

SPN_HOSTNAME=app.example.com
KERBEROS_SERVICE_NAME=HTTP
KERBEROS_REALM=EXAMPLE.COM
KERBEROS_KEYTAB=/run/secrets/service_keytab
KRB5_CONFIG=/run/secrets/krb5.conf
KERBEROS_VERIFY_KINIT=true
KERBEROS_KINIT_TIMEOUT_S=5

LDAP_URI=ldap://dc01.example.com
LDAP_BASE_DN=DC=example,DC=com
LDAP_CONNECT_TIMEOUT_S=5
LDAP_READ_TIMEOUT_S=5
LDAP_RETRY_ATTEMPTS=3
LDAP_RETRY_DELAY_S=0.5

DATABASE_URL=sqlite:////app/users.db
LOG_LEVEL=INFO
RATE_LIMIT_DEFAULT=30 per minute
RATE_LIMIT_AUTH=10 per minute
RATE_LIMIT_STORAGE_URI=redis://redis:6379/0
PREFLIGHT_ENABLED=true
PREFLIGHT_KINIT_ENABLED=true
OTEL_ENABLED=false

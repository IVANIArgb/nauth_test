# Скопируйте содержимое в основной .env рядом с docker-compose.

# Имя хоста как в SPN: HTTP/<KERBEROS_HOSTNAME>@REALM (FQDN веб-приложения)
KERBEROS_HOSTNAME=portal.example.com
KERBEROS_REALM=EXAMPLE.COM
KERBEROS_SERVICE_NAME=HTTP
KERBEROS_KEYTAB=/etc/krb5.keytab

# В контейнере пути фиксированы монтированием (см. docker-compose.kerberos.yml)
KRB5_CONF_PATH=./kerberos/krb5.conf
KRB5_KEYTAB_PATH=./kerberos/http.keytab

# LDAP (атрибуты пользователя из AD)
LDAP_ENABLED=true
LDAP_SERVER=ldap://dc01.example.com:389
LDAP_BASE_DN=DC=example,DC=com
LDAP_USER=EXAMPLE\\svc_learnsite_ldap
LDAP_PASSWORD=change-me
LDAP_USE_SSL=false

# Отключить подмену логина в Docker — иначе Kerberos не используется
DOCKER_AUTH_FALLBACK=false
KERBEROS_GSSAPI_ENABLED=true

SECRET_KEY=замените-на-случайную-строку
